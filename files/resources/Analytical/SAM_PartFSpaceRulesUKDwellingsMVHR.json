  "BedroomCountRules": {
    "CountCategoriesAsBedroom": [
      "Sleeping"
    ],
    "StudioCountsAs": 1,
    "DoNotCountCategories": [
      "Living",
      "LivingKitchen",
      "Cooking",
      "Bathroom",
      "WC",
      "Utility",
      "Transfer",
      "Void"
    ]
  },
  "CalculationRules": {
    "BedroomBasedRateFormula": "19 for Studio or 1 bedroom; 25 for 2; 31 for 3; 37 for 4; 43 for 5; add 6 for each bedroom above 5",
    "AreaBasedRateFormula": "0.3 * sum(space area where IncludeInFloorAreaCheck = true)",
    "WholeDwellingRateFormula": "max(BedroomBasedRate, AreaBasedRate)",
    "ExtractMinimumTotalFormula": "sum(MinFlowRate_Lps for all spaces where VentilationType = extract)",
    "FinalSystemRateFormula": "max(WholeDwellingRate, ExtractMinimumTotal)",
    "BalancingRule": "TotalSupply = FinalSystemRate and TotalExtract = FinalSystemRate"
  },
  "FlowRecalculationRules": {
    "WhenToRecalculate": [
      "AreaBasedRate > BedroomBasedRate",
      "ExtractMinimumTotal > WholeDwellingRate",
      "User requests final terminal flow rates"
    ],
    "SupplyRecalculation": {
      "ApplyToCategories": [
        "Living",
        "Sleeping"
      ],
      "RequiredTotalFormula": "sum(CalculatedFlowRate_Lps for supply spaces) = FinalSystemRate",
      "WeightBasisPriority": [
        "RoomVolume",
        "RoomArea"
      ],
      "Formula": "CalculatedFlowRate_Lps = FinalSystemRate * (SpaceWeight / SumOfAllSupplySpaceWeights)",
      "RoundFlowsTo": 0.01,
      "PreserveMinimumFlow": false
    },
    "ExtractRecalculation": {
      "ApplyToCategories": [
        "LivingKitchen",
        "Cooking",
        "Bathroom",
        "WC",
        "Utility"
      ],
      "Step1": "Assign each extract space its MinFlowRate_Lps",
      "Step2": "ExtraExtractNeeded = FinalSystemRate - ExtractMinimumTotal",
      "Step3": "If ExtraExtractNeeded > 0, distribute extra extract across extract spaces by selected weight basis",
      "RequiredTotalFormula": "sum(CalculatedFlowRate_Lps for extract spaces) = FinalSystemRate",
      "WeightBasisPriority": [
        "WetRoomVolume",
        "RoomVolume",
        "RoomArea"
      ],
      "Formula": "CalculatedFlowRate_Lps = MinFlowRate_Lps + ExtraExtractNeeded * (SpaceWeight / SumOfAllExtractSpaceWeights)",
      "RoundFlowsTo": 0.01,
      "NeverBelowMinimum": true
    },
    "TransferAndVoidRule": {
      "ApplyToCategories": [
        "Transfer",
        "Void"
      ],
      "Formula": "CalculatedFlowRate_Lps = 0"
    }
  },
  "DefaultDwellingAlgorithm": [
    "Classify each space using Categories and Synonyms.",
    "Apply PostProcessingRules.",
    "BedroomCount = count of spaces where IsBedroom = true, except Studio dwelling counts as 1.",
    "InternalFloorArea = sum(area of spaces where IncludeInFloorAreaCheck = true).",
    "BedroomBasedRate = rate from WholeDwellingRates_Lps using BedroomCount.",
    "AreaBasedRate = AreaRate_LpsPerM2 * InternalFloorArea.",
    "WholeDwellingRate = max(BedroomBasedRate, AreaBasedRate).",
    "ExtractMinimumTotal = sum(MinFlowRate_Lps for all extract spaces).",
    "FinalSystemRate = max(WholeDwellingRate, ExtractMinimumTotal).",
    "Recalculate supply room CalculatedFlowRate_Lps so total supply equals FinalSystemRate.",
    "Recalculate extract room CalculatedFlowRate_Lps so total extract equals FinalSystemRate and no extract space is below MinFlowRate_Lps.",
    "Set transfer and void spaces CalculatedFlowRate_Lps = 0."
  ]
}